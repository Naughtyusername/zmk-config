#include "wrappers.dtsi" // qmk logic. has to come after the zmk headers
#define COMBO_TERM_FAST 18
#define COMBO_TERM_MED 30
#define COMBO_TERM_SLOW 50

/ {
    // clang-format off
    combos {
        compatible = "zmk,combos";
// =====================================================================================
//                         COMBO REFERENCE & EDITING GUIDE
// =====================================================================================
//
//  HOW THIS WORKS
//  All combos defined here with bindings, timeouts, and layer locks.
//  key-positions are PLACEHOLDERS (<0 1>) вҖ” override in each board keymap:
//    config/cradio.keymap  (34-key sweep)
//    config/sofle.keymap   (60-key)
//
//  TO ADD A NEW COMBO
//  1. Add the combo node below (copy an existing one as template)
//  2. Set: timeout-ms, bindings, layers  (leave key-positions = <0 1>)
//  3. Override key-positions in EVERY board keymap
//  4. Update this reference table
//
//  POSITION MAPS
//
//  Cradio (34-key):
//   0=Q   1=W   2=E   3=R   4=T в”Ӯ  5=Y   6=U   7=I   8=O   9=P
//  10=A  11=S  12=D  13=F  14=G в”Ӯ 15=H  16=J  17=K  18=L  19=;
//  20=Z  21=X  22=C  23=V  24=B в”Ӯ 25=N  26=M  27=,  28=.  29=/
//                        30  31 в”Ӯ 32  33
//
//  Sofle (60-key):
//   0   1   2   3   4   5       в”Ӯ       6   7   8   9  10  11    вҶҗ number row
//  12  13=Q 14=W 15=E 16=R 17=T в”Ӯ 18=Y 19=U 20=I 21=O 22=P  23
//  24  25=A 26=S 27=D 28=F 29=G в”Ӯ 30=H 31=J 32=K 33=L 34=;  35
//  36  37=Z 38=X 39=C 40=V 41=B в”Ӯ 42  43  44=N 45=M 46=, 47=. 48=/ 49
//              50  51  52  53  54 в”Ӯ 55  56  57  58  59            вҶҗ thumbs
//
//  COMBO INDEX
//  в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
//  в”Ӯ Enum                   в”Ӯ Keys в”Ӯ Output     в”Ӯ Timing  в”Ӯ Layers           в”Ӯ
//  в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
//  в”Ӯ UTILITY                в”Ӯ      в”Ӯ            в”Ӯ         в”Ӯ                  в”Ӯ
//  в”Ӯ  COMBO_HJ_CAPSWORD     в”Ӯ H+J  в”Ӯ CW_TOGG    в”Ӯ MED     в”Ӯ BASE VIM         в”Ӯ
//  в”Ӯ  COMBO_YH_NUMWORD      в”Ӯ Y+H  в”Ӯ NUMWORD    в”Ӯ MED     в”Ӯ BASE VIM         в”Ӯ
//  в”Ӯ  COMBO_JK_ESC          в”Ӯ J+K  в”Ӯ KC_ESC     в”Ӯ MED     в”Ӯ BASE VIM         в”Ӯ
//  в”Ӯ  COMBO_LSCLN_ENT       в”Ӯ L+;  в”Ӯ KC_ENT     в”Ӯ MED     в”Ӯ BASE VIM         в”Ӯ
//  в”Ӯ  COMBO_FG_TAB          в”Ӯ F+G  в”Ӯ KC_TAB     в”Ӯ MED     в”Ӯ BASE VIM LOWER   в”Ӯ
//  в”Ӯ  COMBO_DF_UNDS         в”Ӯ D+F  в”Ӯ KC_UNDS    в”Ӯ MED     в”Ӯ BASE VIM LOWER   в”Ӯ
//  в”Ӯ  COMBO_VB_SPACE        в”Ӯ V+B  в”Ӯ KC_SPACE   в”Ӯ MED     в”Ӯ BASE VIM LOWER   в”Ӯ
//  в”Ӯ  COMBO_AS_BSPC         в”Ӯ A+S  в”Ӯ KC_BSPC    в”Ӯ MED     в”Ӯ BASE VIM LOWER   в”Ӯ
//  в”Ӯ  COMBO_UI_EQUAL        в”Ӯ U+I  в”Ӯ KC_EQUAL   в”Ӯ MED     в”Ӯ BASE LOWER       в”Ӯ
//  в”Ӯ                        в”Ӯ      в”Ӯ            в”Ӯ         в”Ӯ                  в”Ӯ
//  в”Ӯ  COMBO_CV_MINS         в”Ӯ C+V  в”Ӯ KC_MINS    в”Ӯ SLOW    в”Ӯ BASE VIM LOWER   в”Ӯ
//  в”Ӯ  COMBO_ZX_DEL          в”Ӯ Z+X  в”Ӯ KC_DEL     в”Ӯ SLOW    в”Ӯ BASE VIM LOWER   в”Ӯ
//  в”Ӯ  COMBO_DC_ASSEQL       в”Ӯ D+C  в”Ӯ :=         в”Ӯ SLOW    в”Ӯ BASE VIM LOWER   в”Ӯ
//  в”Ӯ  COMBO_GB_LEADER       в”Ӯ G+B  в”Ӯ LEADER     в”Ӯ SLOW    в”Ӯ BASE VIM LOWER   в”Ӯ
//  в”Ӯ  // Leader sequences: EMвҶ’email, GHNвҶ’github, SHвҶ’shebang                  в”Ӯ
//  в”Ӯ                        в”Ӯ      в”Ӯ            в”Ӯ         в”Ӯ                  в”Ӯ
//  в”Ӯ  COMBO_KL_SQT          в”Ӯ K+L  в”Ӯ KC_QUOT    в”Ӯ MED     в”Ӯ BASE VIM         в”Ӯ
//  в”Ӯ  COMBO_JKL_DQT         в”Ӯ JKL  в”Ӯ "          в”Ӯ MED     в”Ӯ BASE VIM         в”Ӯ
//  в”Ӯ  COMBO_KL_SCLN_CCS     в”Ӯ KL;  в”Ӯ : ^ +Shift в”Ӯ MED     в”Ӯ BASE VIM         в”Ӯ
//  в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
//  в”Ӯ AUTO-PAIR              в”Ӯ      в”Ӯ            в”Ӯ         в”Ӯ                  в”Ӯ
//  в”Ӯ  COMBO_NM_PARENS       в”Ӯ N+M  в”Ӯ () + вҶҗ     в”Ӯ MED     в”Ӯ BASE VIM         в”Ӯ
//  в”Ӯ  COMBO_MCOMM_BRACES    в”Ӯ M+,  в”Ӯ {} + вҶҗ     в”Ӯ MED     в”Ӯ BASE VIM         в”Ӯ
//  в”Ӯ  COMBO_COMMDOT_BRACKETSв”Ӯ ,+.  в”Ӯ [] + вҶҗ     в”Ӯ MED     в”Ӯ BASE VIM         в”Ӯ
//  в”Ӯ  COMBO_KCOMM_DQUOTES   в”Ӯ K+,  в”Ӯ "" + вҶҗ     в”Ӯ MED     в”Ӯ BASE VIM         в”Ӯ
//  в”Ӯ  COMBO_JM_SQUOTES      в”Ӯ J+M  в”Ӯ '' + вҶҗ     в”Ӯ MED     в”Ӯ BASE VIM         в”Ӯ
//  в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
//  в”Ӯ ONE-SHOT MODS (GACS)   в”Ӯ      в”Ӯ            в”Ӯ         в”Ӯ                  в”Ӯ
//  в”Ӯ  COMBO_RT_OSM_LSFT     в”Ӯ R+T  в”Ӯ OSM SHIFT  в”Ӯ FAST    в”Ӯ BASE VIM GAM G2 ROG в”Ӯ
//  в”Ӯ  COMBO_YU_OSM_RSFT     в”Ӯ Y+U  в”Ӯ OSM SHIFT  в”Ӯ FAST    в”Ӯ BASE VIM GAM G2 ROG в”Ӯ
//  в”Ӯ  COMBO_QW_OSM_LGUI     в”Ӯ Q+W  в”Ӯ OSM GUI    в”Ӯ FAST    в”Ӯ VIM only            в”Ӯ
//  в”Ӯ  COMBO_WE_OSM_LALT     в”Ӯ W+E  в”Ӯ OSM ALT    в”Ӯ FAST    в”Ӯ VIM only            в”Ӯ
//  в”Ӯ  COMBO_ER_OSM_LCTL     в”Ӯ E+R  в”Ӯ OSM CTRL   в”Ӯ FAST    в”Ӯ VIM GAM G2 ROG      в”Ӯ
//  в”Ӯ  COMBO_UI_OSM_RCTL     в”Ӯ U+I  в”Ӯ OSM CTRL   в”Ӯ FAST    в”Ӯ VIM GAM G2 ROG      в”Ӯ
//  в”Ӯ  COMBO_IO_OSM_RALT     в”Ӯ I+O  в”Ӯ OSM ALT    в”Ӯ FAST    в”Ӯ VIM GAM G2 ROG      в”Ӯ
//  в”Ӯ  COMBO_OP_OSM_RGUI     в”Ӯ O+P  в”Ӯ OSM GUI    в”Ӯ FAST    в”Ӯ VIM GAM G2 ROG      в”Ӯ
//  в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
//  в”Ӯ BASE TOP ROW           в”Ӯ      в”Ӯ            в”Ӯ         в”Ӯ                  в”Ӯ
//  в”Ӯ  COMBO_QW_NOTEQ        в”Ӯ Q+W  в”Ӯ !=         в”Ӯ FAST    в”Ӯ BASE             в”Ӯ
//  в”Ӯ  COMBO_ER_REPEAT       в”Ӯ E+R  в”Ӯ Repeat     в”Ӯ FAST    в”Ӯ BASE             в”Ӯ
//  в”Ӯ  COMBO_IO_COLON        в”Ӯ I+O  в”Ӯ KC_COLON   в”Ӯ FAST    в”Ӯ BASE             в”Ӯ
//  в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
//  в”Ӯ LAYER SWITCHING        в”Ӯ      в”Ӯ            в”Ӯ         в”Ӯ                  в”Ӯ
//  в”Ӯ  COMBO_QWE_TO_BASE     в”Ӯ QWE  в”Ӯ TO(BASE)   в”Ӯ SLOW    в”Ӯ !BASE (anywhere) в”Ӯ
//  в”Ӯ  COMBO_ASD_TO_GAMING   в”Ӯ ASD  в”Ӯ TO(GAMING) в”Ӯ SLOW    в”Ӯ BASE             в”Ӯ
//  в”Ӯ  COMBO_NM_COMM_TO_VIM  в”Ӯ NM,  в”Ӯ TO(VIM)    в”Ӯ SLOW    в”Ӯ BASE             в”Ӯ
//  в”Ӯ  COMBO_YUI_TO_GAMING2  в”Ӯ YUI  в”Ӯ TO(GAMING2)в”Ӯ SLOW    в”Ӯ GAMING           в”Ӯ
//  в”Ӯ  COMBO_HJK_TO_ROGUELIKEв”Ӯ HJK  в”Ӯ TO(ROGUE)  в”Ӯ SLOW    в”Ӯ GAMING           в”Ӯ
//  в”Ӯ  COMBO_YUI_TO_GAMING   в”Ӯ YUI  в”Ӯ TO(GAMING) в”Ӯ SLOW    в”Ӯ GAMING2          в”Ӯ
//  в”Ӯ  COMBO_HJK_TO_GAMING   в”Ӯ HJK  в”Ӯ TO(GAMING) в”Ӯ SLOW    в”Ӯ ROGUELIKE        в”Ӯ
//  в”Ӯ  COMBO_NM_COMM_TO_BASE в”Ӯ NM,  в”Ӯ TO(BASE)   в”Ӯ SLOW    в”Ӯ VIM              в”Ӯ
//  в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
    // For personal formatting use, templating etc.
//  в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
//  в”Ӯ                        в”Ӯ      в”Ӯ            в”Ӯ         в”Ӯ                  в”Ӯ
//  в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
//  в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
//  в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
//  в”Ӯ                        в”Ӯ      в”Ӯ            в”Ӯ         в”Ӯ                  в”Ӯ
//
//  OPEN SLOTS (no combo assigned):
//    2-key:  ZX, XC           (left bottom)
//    3-key:  ZXC, ERT, DFG, CVB, IOP, KL;, ,./
//    vert:   QA, WS, ED, RF, TG, HN, UJ, IK, OL, P;, L., ;/
//    cross:  A;, SL, DK, FJ
//
// =====================================================================================
// Utility combos
// =====================================================================================
        combo_hj_caps_word {
            timeout-ms = <30>;
            key-positions = <0 1>;
            bindings = <&better_caps_word>;
            layers = <BASE VIM>;
        };
        combo_yh_num_word {
            timeout-ms = <18>;
            key-positions = <0 1>;
            bindings = <&num_word LOWER>;
            layers = <BASE VIM>;
        };
        combo_jk_esc {
            timeout-ms = <30>;
            key-positions = <0 1>;
            bindings = <&kp ESC>;
            layers = <BASE VIM>;
        };
        combo_lscln_ent {
            timeout-ms = <30>;
            key-positions = <0 1>;
            bindings = <&kp RET>;
            layers = <BASE VIM>;
        };
        combo_fg_tab {
            timeout-ms = <30>;
            key-positions = <0 1>;
            bindings = <&kp TAB>;
            layers = <BASE VIM LOWER>;
        };
        combo_df_underscore {
            timeout-ms = <30>;
            key-positions = <0 1>;
            bindings = <&kp UNDERSCORE>;
            layers = <BASE VIM LOWER>;
        };
        combo_vb_space {
            timeout-ms = <30>;
            key-positions = <0 1>;
            bindings = <&kp SPACE>;
            layers = <BASE VIM LOWER>;
        };
        combo_cv_minus {
            timeout-ms = <COMBO_TERM_SLOW>;
            key-positions = <0 1>;
            bindings = <&kp MINUS>;
            layers = <BASE VIM LOWER>;
        };
        combo_zx_del {
            timeout-ms = <COMBO_TERM_SLOW>;
            key-positions = <0 1>;
            bindings = <&kp DEL>;
            layers = <BASE VIM LOWER>;
        };
        combo_dc_assign {
            timeout-ms = <COMBO_TERM_SLOW>;
            key-positions = <0 1>;
            bindings = <&assign>;
            layers = <BASE VIM LOWER>;
        };
        combo_gb_leader {
            timeout-ms = <COMBO_TERM_SLOW>;
            key-positions = <0 1>;
            bindings = <&leader>;
            layers = <BASE VIM LOWER>;
        };
        combo_as_bspc {
            timeout-ms = <30>;
            key-positions = <0 1>;
            bindings = <&kp BSPC>;
            layers = <BASE VIM LOWER>;
        };
        combo_ui_equal {
            timeout-ms = <30>;
            key-positions = <0 1>;
            bindings = <&kp EQUAL>;
            layers = <BASE LOWER>;
        };
        combo_kl_sqt {
            timeout-ms = <30>;
            key-positions = <0 1>;
            bindings = <&kp SQT>;
            layers = <BASE VIM>;
        };
        combo_jkl_dqt {
            timeout-ms = <30>;
            key-positions = <0 1 2>;
            bindings = <&kp DQT>;
            layers = <BASE VIM>;
        };
        combo_kl_scln_ccs: combo_kl_scln_ccs {
            timeout-ms = <30>;
            key-positions = <0 1 2>;
            bindings = <&colon_caret_shift>;
            layers = <BASE VIM>;
        };
// =====================================================================================
// Three-finger layer switching combos
// =====================================================================================
        combo_return_to_base {
            timeout-ms = <50>;
            key-positions = <0 1 2>;
            bindings = <&to 0>;
            layers = <BASE GAMING GAMING2 ROGUELIKE VIM>;
        };
        combo_base_to_gaming {
            timeout-ms = <50>;
            key-positions = <0 1 2>;
            bindings = <&to GAMING>;
            layers = <BASE>;
        };
        combo_base_to_vim {
            timeout-ms = <50>;
            key-positions = <0 1 2>;
            bindings = <&to VIM>;
            layers = <BASE>;
        };
        combo_vim_to_base {
            timeout-ms = <50>;
            key-positions = <0 1 2>;
            bindings = <&to BASE>;
            layers = <VIM>;
        };
        combo_gaming_to_roguelike {
            timeout-ms = <50>;
            key-positions = <0 1 2>;
            bindings = <&to ROGUELIKE>;
            layers = <GAMING>;
        };
        combo_roguelike_to_gaming {
            timeout-ms = <50>;
            key-positions = <0 1 2>;
            bindings = <&to GAMING>;
            layers = <ROGUELIKE>;
        };
        combo_gaming_to_gaming2 {
            timeout-ms = <50>;
            key-positions = <0 1 2>;
            bindings = <&to GAMING2>;
            layers = <GAMING>;
        };
        combo_gaming2_to_gaming {
            timeout-ms = <50>;
            key-positions = <0 1 2>;
            bindings = <&to GAMING>;
            layers = <GAMING2>;
        };
// =====================================================================================
// Auto-pair combos вҖ” types pair and moves cursor inside
// =====================================================================================
        combo_nm_parens: combo_nm_parens {
            timeout-ms = <30>;
            key-positions = <0 1>;
            bindings = <&macro_parens>;
            layers = <BASE VIM>;
        };
